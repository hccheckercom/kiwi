<?php
/**
 * Account Notifications
 */

if ( ! function_exists( 'wezone_is_active' ) ) {
	return;
}

if ( ! is_user_logged_in() ) {
	wp_redirect( home_url( '/dang-nhap' ) );
	exit;
}

$user_id       = get_current_user_id();
$notifications = function_exists( 'wz_get_user_notifications' ) ? wz_get_user_notifications( $user_id, array( 'per_page' => 20 ) ) : array();
?>

<?php get_header(); ?>

<main id="main" class="site-main">
	<div class="container mx-auto px-4 py-8">

		<nav class="breadcrumb mb-6 text-sm" aria-label="Breadcrumb">
			<a href="<?php echo esc_url( home_url() ); ?>" class="text-gray-600 hover:text-primary">Trang chủ</a>
			<span class="mx-2" aria-hidden="true">/</span>
			<a href="<?php echo esc_url( home_url( '/tai-khoan' ) ); ?>" class="text-gray-600 hover:text-primary">Tài khoản</a>
			<span class="mx-2" aria-hidden="true">/</span>
			<span class="text-gray-900">Thông báo</span>
		</nav>

		<div class="grid grid-cols-1 lg:grid-cols-4 gap-8">

			<aside class="lg:col-span-1">
				<?php get_template_part( 'template-parts/account/sidebar', null, array( 'active_tab' => 'notifications' ) ); ?>
			</aside>

			<div class="lg:col-span-3">
				<div class="flex items-center justify-between mb-4">
					<h1 class="text-xl font-semibold">Thông báo</h1>
					<?php if ( ! empty( $notifications ) ) : ?>
					<button type="button" id="wz-mark-all-read"
					        class="text-sm text-primary hover:underline">
						Đánh dấu tất cả đã đọc
					</button>
					<?php endif; ?>
				</div>

				<?php if ( ! empty( $notifications ) ) : ?>
				<div class="space-y-2" id="wz-notification-list">
					<?php foreach ( $notifications as $notif ) : ?>
					<div class="bg-white rounded-xl shadow-sm p-4 flex gap-4 <?php echo esc_attr( empty( $notif['is_read'] ) ? 'border-l-4 border-primary' : '' ); ?>"
					     data-notif-id="<?php echo esc_attr( $notif['id'] ); ?>">
						<div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
							<span class="material-icons text-primary text-lg" aria-hidden="true">
								<?php echo esc_html( $notif['icon'] ?? 'notifications' ); ?>
							</span>
						</div>
						<div class="flex-1 min-w-0">
							<p class="font-medium text-sm <?php echo esc_attr( empty( $notif['is_read'] ) ? 'text-gray-900' : 'text-gray-600' ); ?>">
								<?php echo esc_html( $notif['title'] ); ?>
							</p>
							<p class="text-sm text-gray-500 mt-0.5"><?php echo esc_html( $notif['message'] ); ?></p>
							<p class="text-xs text-gray-400 mt-1"><?php echo esc_html( human_time_diff( strtotime( $notif['created_at'] ) ) ); ?> trước</p>
						</div>
						<?php if ( ! empty( $notif['url'] ) ) : ?>
						<a href="<?php echo esc_url( $notif['url'] ); ?>" class="flex-shrink-0 text-primary hover:underline text-sm self-center">Xem</a>
						<?php endif; ?>
					</div>
					<?php endforeach; ?>
				</div>
				<?php else : ?>
				<div class="bg-white rounded-xl shadow-sm p-12 text-center text-gray-500">
					<span class="material-icons text-5xl mb-3 block text-gray-300" aria-hidden="true">notifications_none</span>
					<p class="font-medium">Không có thông báo nào</p>
				</div>
				<?php endif; ?>
			</div>
		</div>
	</div>
</main>

<?php get_footer(); ?>