<script>
(function() {
	var form = document.getElementById('wz-contact-form');
	if (!form) return;

	form.addEventListener('submit', function(e) {
		e.preventDefault();
		var btn = document.getElementById('wz-contact-submit');
		var msg = document.getElementById('wz-contact-message');
		btn.disabled = true;
		btn.textContent = 'Đang gửi...';
		msg.className = 'hidden rounded-lg p-4 text-sm';

		var data = new FormData(form);
		data.append('action', 'wz_contact_form');

		fetch('<?php echo esc_url( admin_url( 'admin-ajax.php' ) ); ?>', {
			method: 'POST',
			body: data,
			credentials: 'same-origin',
		})
		.then(function(r) { return r.json(); })
		.then(function(res) {
			if (res.success) {
				msg.className = 'rounded-lg p-4 text-sm bg-green-50 text-green-700';
				msg.textContent = res.data.message || 'Đã gửi thành công! Chúng tôi sẽ phản hồi trong 24h.';
				form.reset();
			} else {
				msg.className = 'rounded-lg p-4 text-sm bg-red-50 text-red-700';
				msg.textContent = res.data || 'Có lỗi xảy ra. Vui lòng thử lại.';
			}
		})
		.catch(function() {
			msg.className = 'rounded-lg p-4 text-sm bg-red-50 text-red-700';
			msg.textContent = 'Có lỗi xảy ra. Vui lòng thử lại.';
		})
		.finally(function() {
			btn.disabled = false;
			btn.textContent = 'Gửi tin nhắn';
		});
	});
})();
</script>

