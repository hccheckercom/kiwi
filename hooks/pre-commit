#!/usr/bin/env python3
"""Pre-commit hook — Scan staged files for CRITICAL violations.

Install:
    ln -s ../../.claude/kiwi/hooks/pre-commit .git/hooks/pre-commit
    chmod +x .git/hooks/pre-commit

Or for Windows:
    Copy this file to .git/hooks/pre-commit
"""

import os
import subprocess
import sys
from pathlib import Path

# Add Kiwi to path
KIWI_DIR = Path(__file__).parent.parent
sys.path.insert(0, str(KIWI_DIR))


def get_staged_files():
    """Get list of staged files."""
    try:
        result = subprocess.run(
            ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
            capture_output=True,
            text=True,
            check=True,
        )
        files = [f.strip() for f in result.stdout.split("\n") if f.strip()]
        return files
    except subprocess.CalledProcessError:
        return []


def filter_scannable_files(files):
    """Filter to only PHP/JS/CSS/TS/TSX files."""
    extensions = {".php", ".js", ".css", ".ts", ".tsx", ".jsx"}
    return [f for f in files if Path(f).suffix in extensions]


def scan_files(files):
    """Scan files with Kiwi scanner."""
    from scanner.cli import scan_theme
    from scanner.models import Report

    # Get git root
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True,
            text=True,
            check=True,
        )
        git_root = result.stdout.strip()
    except subprocess.CalledProcessError:
        git_root = os.getcwd()

    # Scan each file
    violations = []
    for file in files:
        file_path = os.path.join(git_root, file)
        if not os.path.exists(file_path):
            continue

        try:
            # Scan single file
            report = scan_theme(
                file_path,
                severity_filter="CRITICAL",
                skip_empty_scope=True,
            )

            for v in report.violations:
                violations.append({
                    "file": file,
                    "line": v.line,
                    "lesson_id": v.lesson_id,
                    "description": v.description,
                })
        except Exception as e:
            print(f"Warning: Failed to scan {file}: {e}", file=sys.stderr)
            continue

    return violations


def main():
    """Main pre-commit hook logic."""
    # Get staged files
    staged = get_staged_files()
    if not staged:
        # No staged files, allow commit
        sys.exit(0)

    # Filter to scannable files
    scannable = filter_scannable_files(staged)
    if not scannable:
        # No scannable files, allow commit
        sys.exit(0)

    print(f"[Kiwi] Scanning {len(scannable)} staged files for CRITICAL violations...")

    # Scan files
    violations = scan_files(scannable)

    if not violations:
        print("[Kiwi] ✓ No CRITICAL violations found")
        sys.exit(0)

    # Block commit if violations found
    print(f"\n[Kiwi] ✗ Found {len(violations)} CRITICAL violations:\n")
    for v in violations[:10]:  # Show first 10
        print(f"  {v['file']}:{v['line']} — {v['lesson_id']}: {v['description']}")

    if len(violations) > 10:
        print(f"  ... and {len(violations) - 10} more")

    print("\nFix violations before committing, or use --no-verify to skip this check.")
    sys.exit(1)


if __name__ == "__main__":
    main()