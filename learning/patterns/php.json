{
  "_version": 1,
  "_description": "PHP dangerous pattern catalog — Kiwi auto-detect + gap-fill",
  "patterns": [
    {
      "id": "php_hardcoded_credentials",
      "category": "security",
      "severity": "CRITICAL",
      "title": "Hardcoded Credentials in Source Code",
      "detect": "(password|secret|api_key|token)\\s*=\\s*[\"'][^\"']+[\"']",
      "scope": "**/*.php",
      "pattern": "(password|secret|api_key|token)\\s*=\\s*[\"'][^\"']+[\"']",
      "bad": "define(\"API_KEY\", \"sk_live_abc123\");",
      "good": "define(\"API_KEY\", getenv(\"API_KEY\"));",
      "why": "Hardcoded credentials in source code can be exposed via version control"
    },
    {
      "id": "php_sql_injection",
      "category": "security",
      "severity": "CRITICAL",
      "title": "SQL Injection via String Concatenation",
      "detect": "\\$wpdb->(query|get_results).*\\.\\s*\\$",
      "scope": "**/*.php",
      "pattern": "\\$wpdb->(query|get_results).*\\.\\s*\\$",
      "bad": "$wpdb->query(\"SELECT * FROM table WHERE id = \" . $_GET[\"id\"]);",
      "good": "$wpdb->prepare(\"SELECT * FROM table WHERE id = %d\", $_GET[\"id\"]);",
      "why": "String concatenation in SQL queries enables SQL injection attacks"
    },
    {
      "id": "php_xss_risk",
      "category": "security",
      "severity": "HIGH",
      "title": "XSS Risk - Unescaped Output",
      "detect": "echo\\s+\\$(?!.*esc_)",
      "scope": "**/*.php",
      "pattern": "echo\\s+\\$(?!.*esc_)",
      "bad": "echo $user_input;",
      "good": "echo esc_html($user_input);",
      "why": "Unescaped output enables XSS attacks"
    },
    {
      "id": "php_missing_nonce",
      "category": "security",
      "severity": "HIGH",
      "title": "Missing Nonce Verification in Form Handler",
      "detect": "isset\\(\\$_POST",
      "detect_exclude": "wp_verify_nonce",
      "scope": "**/*.php",
      "pattern": "isset\\(\\$_POST.*(?!.*wp_verify_nonce)",
      "bad": "if (isset($_POST[\"action\"])) { process(); }",
      "good": "if (isset($_POST[\"action\"]) && wp_verify_nonce($_POST[\"_wpnonce\"], \"action\")) { process(); }",
      "why": "Missing nonce check enables CSRF attacks"
    },
    {
      "id": "php_file_inclusion",
      "category": "security",
      "severity": "CRITICAL",
      "title": "Arbitrary File Inclusion Risk",
      "detect": "(include|require)(_once)?\\s*\\(\\s*\\$",
      "scope": "**/*.php",
      "pattern": "(include|require)(_once)?\\s*\\(\\s*\\$",
      "bad": "include($_GET[\"page\"] . \".php\");",
      "good": "$allowed = [\"home\", \"about\"]; if (in_array($_GET[\"page\"], $allowed)) include($_GET[\"page\"] . \".php\");",
      "why": "Dynamic file inclusion with user input enables arbitrary code execution"
    },
    {
      "id": "php_hardcoded_url",
      "category": "portability",
      "severity": "HIGH",
      "title": "Hardcoded URL Instead of WordPress Functions",
      "detect": "https?://[a-z0-9.-]+\\.[a-z]{2,}",
      "detect_exclude": "home_url|site_url",
      "scope": "**/*.php",
      "pattern": "https?://[a-z0-9.-]+\\.[a-z]{2,}",
      "bad": "$url = \"https://example.com/wp-content/uploads/\";",
      "good": "$url = wp_upload_dir()[\"baseurl\"] . \"/\";",
      "why": "Hardcoded URLs break when site domain changes"
    },
    {
      "id": "php_missing_error_handling",
      "category": "reliability",
      "severity": "HIGH",
      "title": "Missing Error Handling for External Calls",
      "detect": "(wp_remote_get|file_get_contents|curl_exec)\\(",
      "scope": "**/*.php",
      "pattern": "(wp_remote_get|file_get_contents|curl_exec)\\(",
      "bad": "$data = wp_remote_get($url);",
      "good": "$response = wp_remote_get($url); if (is_wp_error($response)) return;",
      "why": "External calls can fail; missing error handling causes fatal errors"
    },
    {
      "id": "php_deprecated_function",
      "category": "compatibility",
      "severity": "HIGH",
      "title": "Deprecated PHP Function Usage",
      "detect": "(mysql_query|ereg|split|create_function)\\(",
      "scope": "**/*.php",
      "pattern": "(mysql_query|ereg|split|create_function)\\(",
      "bad": "mysql_query(\"SELECT * FROM table\");",
      "good": "$wpdb->get_results(\"SELECT * FROM table\");",
      "why": "Deprecated functions removed in PHP 7+ cause fatal errors"
    },
    {
      "id": "php_inefficient_loop",
      "category": "performance",
      "severity": "SUGGEST",
      "title": "Inefficient Loop - count() in Condition",
      "detect": "(for|while).*count\\(",
      "scope": "**/*.php",
      "pattern": "(for|while).*count\\(",
      "bad": "for ($i = 0; $i < count($arr); $i++) {}",
      "good": "$len = count($arr); for ($i = 0; $i < $len; $i++) {}",
      "why": "count() called every iteration causes O(n²) complexity"
    },
    {
      "id": "php_missing_sanitization",
      "category": "security",
      "severity": "HIGH",
      "title": "Missing Input Sanitization",
      "detect": "\\$_(GET|POST|REQUEST)\\[",
      "detect_exclude": "sanitize_|absint|intval|esc_",
      "scope": "**/*.php",
      "pattern": "\\$_(GET|POST|REQUEST)\\[(?!.*sanitize_)",
      "bad": "$name = $_POST[\"name\"];",
      "good": "$name = sanitize_text_field($_POST[\"name\"]);",
      "why": "Unsanitized user input can cause security vulnerabilities"
    },
    {
      "id": "php_extract_usage",
      "category": "security",
      "severity": "CRITICAL",
      "title": "extract() — Variable Injection Risk",
      "detect": "\\bextract\\s*\\(",
      "scope": "**/*.php",
      "pattern": "\\bextract\\s*\\(",
      "bad": "extract($_POST);",
      "good": "$name = sanitize_text_field($_POST['name']);",
      "why": "extract() creates variables from array keys, enabling variable injection from user input"
    },
    {
      "id": "php_unserialize",
      "category": "security",
      "severity": "CRITICAL",
      "title": "unserialize() on User Input — Object Injection",
      "detect": "unserialize\\s*\\(\\s*\\$",
      "scope": "**/*.php",
      "pattern": "unserialize\\s*\\(\\s*\\$",
      "bad": "$data = unserialize($_COOKIE['prefs']);",
      "good": "$data = json_decode($_COOKIE['prefs'], true);",
      "why": "unserialize() on untrusted input enables PHP object injection attacks"
    },
    {
      "id": "php_exec_shell",
      "category": "security",
      "severity": "CRITICAL",
      "title": "Shell Execution Functions — Command Injection",
      "detect": "\\b(exec|system|passthru|shell_exec|popen|proc_open)\\s*\\(",
      "scope": "**/*.php",
      "pattern": "(exec|system|passthru|shell_exec)\\s*\\(",
      "bad": "exec(\"convert \" . $_GET['file']);",
      "good": "exec('convert ' . escapeshellarg($file));",
      "why": "Shell execution with unsanitized input enables command injection"
    },
    {
      "id": "php_wpdb_no_prepare",
      "category": "security",
      "severity": "CRITICAL",
      "title": "$wpdb->query() Without prepare() — SQL Injection",
      "detect": "\\$wpdb->query\\s*\\(\\s*[\"']",
      "detect_exclude": "\\$wpdb->prepare",
      "scope": "**/*.php",
      "pattern": "\\$wpdb->query\\s*\\(\\s*[\"']",
      "bad": "$wpdb->query(\"DELETE FROM $table WHERE id = $id\");",
      "good": "$wpdb->query($wpdb->prepare(\"DELETE FROM $table WHERE id = %d\", $id));",
      "why": "Direct queries without prepare() are vulnerable to SQL injection"
    },
    {
      "id": "php_header_injection",
      "category": "security",
      "severity": "HIGH",
      "title": "Header Injection via Unvalidated Input",
      "detect": "header\\s*\\(.*\\$_(GET|POST|REQUEST|SERVER)",
      "scope": "**/*.php",
      "pattern": "header\\(.*\\$_",
      "bad": "header('Location: ' . $_GET['redirect']);",
      "good": "header('Location: ' . esc_url($_GET['redirect']));",
      "why": "HTTP header injection enables response splitting and open redirect attacks"
    }
  ]
}