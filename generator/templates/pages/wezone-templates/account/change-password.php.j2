</main>

<script>
(function() {
	var form = document.getElementById('wz-change-password-form');
	if (!form) return;
	form.addEventListener('submit', function(e) {
		e.preventDefault();
		var newPw = document.getElementById('new-password').value;
		var confirmPw = document.getElementById('confirm-password').value;
		var msg = document.getElementById('wz-password-message');
		if (newPw !== confirmPw) {
			msg.className = 'rounded-lg p-4 text-sm mb-4 bg-red-50 text-red-700';
			msg.textContent = 'Mật khẩu xác nhận không khớp.';
			return;
		}
		var btn = document.getElementById('wz-password-submit');
		btn.disabled = true;
		var data = new FormData(form);
		data.append('action', 'wz_change_password');
		fetch('<?php echo esc_url( admin_url( 'admin-ajax.php' ) ); ?>', { method: 'POST', body: data, credentials: 'same-origin' })
			.then(function(r) { return r.json(); })
			.then(function(res) {
				msg.className = 'rounded-lg p-4 text-sm mb-4 ' + (res.success ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700');
				msg.textContent = res.success ? 'Đã đổi mật khẩu thành công.' : (res.data || 'Có lỗi xảy ra.');
				if (res.success) form.reset();
			})
			.catch(function() {
				msg.className = 'rounded-lg p-4 text-sm mb-4 bg-red-50 text-red-700';
				msg.textContent = 'Có lỗi xảy ra. Vui lòng thử lại.';
			})
			.finally(function() { btn.disabled = false; });
	});
})();
</script>

