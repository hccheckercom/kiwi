/**
 * Mock Data Layer
 *
 * Provides stub functions for standalone theme testing without Wezone Core.
 * Enables UI/UX preview with sample products, cart, and config data.
 *
 * @package {{ theme_slug }}
 */

if ( ! defined( 'ABSPATH' ) ) {
	exit;
}

/**
 * Mock wz_config() - Shop configuration
 */
if ( ! function_exists( 'wz_config' ) ) {
	function wz_config( $key = null ) {
		$config = [
			'name'    => '{{ shop_name }}',
			'tagline' => 'Chất lượng - Uy tín - Giá tốt',
			'phone'   => '1900 xxxx',
			'email'   => 'contact@example.com',
			'logo'    => '',
			'theme'   => [
				'primary'   => '{{ primary_color }}',
				'secondary' => '{{ secondary_color }}',
				'font'      => '{{ font_family }}',
			],
			'shipping' => [
				'fees' => [
					'default' => 30000,
					'express' => 50000,
				],
			],
			'bank_info' => [
				'bank_name'      => 'Vietcombank',
				'account_number' => '1234567890',
				'account_name'   => '{{ shop_name }}',
			],
			'social' => [
				'facebook_url' => 'https://facebook.com',
				'zalo_url'     => 'https://zalo.me',
			],
			'footer' => [
				'copyright'  => '© 2026 {{ shop_name }}. All rights reserved.',
				'powered_by' => 'Powered by Wezone',
			],
		];

		if ( $key === null ) {
			return $config;
		}

		// Support dot notation (e.g., 'theme.primary')
		$keys = explode( '.', $key );
		$value = $config;
		foreach ( $keys as $k ) {
			if ( isset( $value[ $k ] ) ) {
				$value = $value[ $k ];
			} else {
				return null;
			}
		}

		return $value;
	}
}

