/**
 * Register mock menus
 */
add_action( 'after_setup_theme', '{{ theme_slug_underscore }}_register_mock_menus' );
function {{ theme_slug_underscore }}_register_mock_menus() {
	register_nav_menus( [
		'primary' => 'Primary Menu',
		'footer'  => 'Footer Menu',
	] );
}

/**
 * Create mock menu items if menus are empty
 */
add_action( 'wp_nav_menu_args', '{{ theme_slug_underscore }}_mock_menu_fallback' );
function {{ theme_slug_underscore }}_mock_menu_fallback( $args ) {
	if ( ! has_nav_menu( $args['theme_location'] ) ) {
		$args['fallback_cb'] = function() {
			echo '<ul class="menu">';
			echo '<li><a href="' . home_url() . '">Trang chủ</a></li>';
			echo '<li><a href="' . home_url( '/shop' ) . '">Sản phẩm</a></li>';
			echo '<li><a href="' . home_url( '/about' ) . '">Giới thiệu</a></li>';
			echo '<li><a href="' . home_url( '/contact' ) . '">Liên hệ</a></li>';
			echo '</ul>';
		};
	}
	return $args;
}
