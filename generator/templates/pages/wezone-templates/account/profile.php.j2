<script>
(function() {
	var form = document.getElementById('wz-profile-form');
	if (!form) return;
	form.addEventListener('submit', function(e) {
		e.preventDefault();
		var btn = document.getElementById('wz-profile-submit');
		var msg = document.getElementById('wz-profile-message');
		btn.disabled = true;
		var data = new FormData(form);
		data.append('action', 'wz_update_profile');
		fetch('<?php echo esc_url( admin_url( 'admin-ajax.php' ) ); ?>', { method: 'POST', body: data, credentials: 'same-origin' })
			.then(function(r) { return r.json(); })
			.then(function(res) {
				msg.className = 'rounded-lg p-4 text-sm mb-4 ' + (res.success ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700');
				msg.textContent = res.success ? 'Đã cập nhật thông tin thành công.' : (res.data || 'Có lỗi xảy ra.');
			})
			.catch(function() {
				msg.className = 'rounded-lg p-4 text-sm mb-4 bg-red-50 text-red-700';
				msg.textContent = 'Có lỗi xảy ra. Vui lòng thử lại.';
			})
			.finally(function() { btn.disabled = false; });
	});
})();
</script>

