<?php
/**
 * Account Wallet
 */

if ( ! function_exists( 'wezone_is_active' ) ) {
	return;
}

if ( ! is_user_logged_in() ) {
	wp_redirect( home_url( '/dang-nhap' ) );
	exit;
}

$user_id = get_current_user_id();
$balance = function_exists( 'wz_get_wallet_balance' ) ? wz_get_wallet_balance( $user_id ) : 0;
$history = function_exists( 'wz_get_wallet_history' ) ? wz_get_wallet_history( $user_id, array( 'limit' => 20 ) ) : array();
?>

<?php get_header(); ?>

<main id="main" class="site-main">
	<div class="container mx-auto px-4 py-8">

		<nav class="breadcrumb mb-6 text-sm" aria-label="Breadcrumb">
			<a href="<?php echo esc_url( home_url() ); ?>" class="text-gray-600 hover:text-primary">Trang chủ</a>
			<span class="mx-2" aria-hidden="true">/</span>
			<a href="<?php echo esc_url( home_url( '/tai-khoan' ) ); ?>" class="text-gray-600 hover:text-primary">Tài khoản</a>
			<span class="mx-2" aria-hidden="true">/</span>
			<span class="text-gray-900">Ví số dư</span>
		</nav>

		<div class="grid grid-cols-1 lg:grid-cols-4 gap-8">

			<aside class="lg:col-span-1">
				<?php get_template_part( 'template-parts/account/sidebar', null, array( 'active_tab' => 'wallet' ) ); ?>
			</aside>

			<div class="lg:col-span-3 space-y-6">

				<div class="bg-gradient-to-r from-primary to-secondary rounded-2xl p-6 text-white">
					<p class="text-sm text-white/70 mb-1">Số dư ví</p>
					<p class="text-4xl font-bold"><?php echo esc_html( wz_format_price( $balance ) ); ?></p>
					<p class="text-sm text-white/70 mt-2">Dùng để thanh toán đơn hàng</p>
				</div>

				<div class="bg-white rounded-xl shadow-sm p-6">
					<h2 class="font-semibold mb-4">Lịch sử giao dịch</h2>
					<?php if ( ! empty( $history ) ) : ?>
					<div class="divide-y divide-gray-100">
						<?php foreach ( $history as $tx ) : ?>
						<div class="flex items-center justify-between py-3">
							<div>
								<p class="font-medium text-sm"><?php echo esc_html( $tx['description'] ); ?></p>
								<p class="text-xs text-gray-500 mt-0.5"><?php echo esc_html( date_i18n( 'd/m/Y H:i', strtotime( $tx['created_at'] ) ) ); ?></p>
							</div>
							<span class="font-bold <?php echo esc_attr( $tx['amount'] > 0 ? 'text-green-600' : 'text-red-500' ); ?>">
								<?php echo esc_html( ( $tx['amount'] > 0 ? '+' : '' ) . wz_format_price( $tx['amount'] ) ); ?>
							</span>
						</div>
						<?php endforeach; ?>
					</div>
					<?php else : ?>
					<p class="text-gray-500 text-sm text-center py-8">Chưa có giao dịch nào</p>
					<?php endif; ?>
				</div>

			</div>
		</div>
	</div>
</main>

<?php get_footer(); ?>
