<?php
/**
 * Account Orders
 */

if ( ! function_exists( 'wezone_is_active' ) ) {
	return;
}

if ( ! is_user_logged_in() ) {
	wp_redirect( home_url( '/dang-nhap' ) );
	exit;
}

$user_id     = get_current_user_id();
$status_filter = isset( $_GET['status'] ) ? sanitize_key( $_GET['status'] ) : '';
$page        = isset( $_GET['paged'] ) ? max( 1, absint( $_GET['paged'] ) ) : 1;
$args        = array( 'page' => $page, 'per_page' => 10 );
if ( $status_filter ) {
	$args['status'] = $status_filter;
}
$orders = function_exists( 'wz_get_user_orders' ) ? wz_get_user_orders( $user_id, $args ) : array();

$status_tabs = array(
	''           => 'Tất cả',
	'pending'    => 'Chờ xác nhận',
	'processing' => 'Đang giao',
	'completed'  => 'Hoàn thành',
	'cancelled'  => 'Đã hủy',
);
?>

<?php get_header(); ?>

<main id="main" class="site-main">
	<div class="container mx-auto px-4 py-8">

		<nav class="breadcrumb mb-6 text-sm" aria-label="Breadcrumb">
			<a href="<?php echo esc_url( home_url() ); ?>" class="text-gray-600 hover:text-primary">Trang chủ</a>
			<span class="mx-2" aria-hidden="true">/</span>
			<a href="<?php echo esc_url( home_url( '/tai-khoan' ) ); ?>" class="text-gray-600 hover:text-primary">Tài khoản</a>
			<span class="mx-2" aria-hidden="true">/</span>
			<span class="text-gray-900">Đơn hàng</span>
		</nav>

		<div class="grid grid-cols-1 lg:grid-cols-4 gap-8">

			<aside class="lg:col-span-1">
				<?php get_template_part( 'template-parts/account/sidebar', null, array( 'active_tab' => 'orders' ) ); ?>
			</aside>

			<div class="lg:col-span-3">
				<h1 class="text-xl font-semibold mb-4">Lịch sử đơn hàng</h1>

				<div class="flex gap-1 mb-6 overflow-x-auto border-b border-gray-200">
					<?php foreach ( $status_tabs as $key => $label ) : ?>
					<a href="<?php echo esc_url( add_query_arg( 'status', $key, home_url( '/tai-khoan/don-hang' ) ) ); ?>"
					   class="flex-shrink-0 px-4 py-2 text-sm font-medium border-b-2 -mb-px transition-colors
					          <?php echo esc_attr( $status_filter === $key ? 'border-primary text-primary' : 'border-transparent text-gray-600 hover:text-gray-900' ); ?>">
						<?php echo esc_html( $label ); ?>
					</a>
					<?php endforeach; ?>
				</div>

				<?php if ( ! empty( $orders ) ) : ?>
				<div class="space-y-4">
					<?php foreach ( $orders as $order ) : ?>
					<div class="bg-white rounded-xl shadow-sm p-5">
						<div class="flex flex-wrap items-center justify-between gap-3 mb-4">
							<div class="flex items-center gap-3">
								<span class="font-mono text-sm font-bold">#<?php echo esc_html( $order['id'] ); ?></span>
								<span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium
									<?php echo esc_attr( wz_order_status_class( $order['status'] ) ); ?>">
									<?php echo esc_html( wz_order_status_label( $order['status'] ) ); ?>
								</span>
							</div>
							<span class="text-sm text-gray-500"><?php echo esc_html( date_i18n( 'd/m/Y H:i', strtotime( $order['date_created'] ) ) ); ?></span>
						</div>

						<?php if ( ! empty( $order['items'] ) ) : ?>
						<div class="flex gap-2 mb-4">
							<?php foreach ( array_slice( $order['items'], 0, 2 ) as $item ) : ?>
							<?php if ( ! empty( $item['thumbnail'] ) ) : ?>
							<img src="<?php echo esc_url( $item['thumbnail'] ); ?>"
							     alt="<?php echo esc_attr( $item['name'] ); ?>"
							     class="w-12 h-12 rounded-lg object-cover"
							     width="48" height="48">
							<?php endif; ?>
							<?php endforeach; ?>
							<?php if ( count( $order['items'] ) > 2 ) : ?>
							<div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center text-xs text-gray-500">
								+<?php echo esc_html( (string) ( count( $order['items'] ) - 2 ) ); ?>
							</div>
							<?php endif; ?>
						</div>
						<?php endif; ?>

						<div class="flex flex-wrap items-center justify-between gap-3">
							<div class="text-sm text-gray-600">
								<?php echo esc_html( (string) count( $order['items'] ?? array() ) ); ?> sản phẩm &bull;
								<span class="font-semibold text-gray-900"><?php echo esc_html( wz_format_price( $order['total'] ) ); ?></span>
							</div>
							<div class="flex gap-2">
								<a href="<?php echo esc_url( home_url( '/tai-khoan/don-hang/' . $order['id'] ) ); ?>"
								   class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm hover:border-primary hover:text-primary transition-colors">
									Xem chi tiết
								</a>
								<?php if ( in_array( $order['status'], array( 'processing', 'shipping' ), true ) ) : ?>
								<a href="<?php echo esc_url( home_url( '/tai-khoan/theo-doi-don?order=' . $order['id'] ) ); ?>"
								   class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm hover:border-primary hover:text-primary transition-colors">
									Theo dõi
								</a>
								<?php endif; ?>
								<?php if ( $order['status'] === 'completed' ) : ?>
								<button type="button" class="px-3 py-1.5 bg-primary text-white rounded-lg text-sm hover:opacity-90 transition-opacity wz-reorder"
								        data-order-id="<?php echo esc_attr( $order['id'] ); ?>">
									Mua lại
								</button>
								<?php endif; ?>
							</div>
						</div>
					</div>
					<?php endforeach; ?>
				</div>
				<?php else : ?>
				<div class="bg-white rounded-xl shadow-sm p-12 text-center text-gray-500">
					<span class="material-icons text-5xl mb-3 block text-gray-300" aria-hidden="true">shopping_bag</span>
					<p class="font-medium">Bạn chưa có đơn hàng nào</p>
					<a href="<?php echo esc_url( function_exists( 'wz_get_shop_url' ) ? wz_get_shop_url() : home_url( '/shop' ) ); ?>"
					   class="inline-block mt-4 px-6 py-2 bg-primary text-white rounded-lg text-sm hover:opacity-90 transition-opacity">
						Mua sắm ngay
					</a>
				</div>
				<?php endif; ?>
			</div>
		</div>
	</div>
</main>

<?php get_footer(); ?>
