<?php
/**
 * Account Order Detail
 */

if ( ! function_exists( 'wezone_is_active' ) ) {
	return;
}

if ( ! is_user_logged_in() ) {
	wp_redirect( home_url( '/dang-nhap' ) );
	exit;
}

$user_id  = get_current_user_id();
$order_id = (int) get_query_var( 'order_id', 0 );
if ( ! $order_id ) {
	wp_redirect( home_url( '/tai-khoan/don-hang' ) );
	exit;
}

$order = function_exists( 'wz_get_order' ) ? wz_get_order( $order_id ) : null;
if ( ! $order || (int) $order['user_id'] !== $user_id ) {
	wp_redirect( home_url( '/tai-khoan/don-hang' ) );
	exit;
}
?>

